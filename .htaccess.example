<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Root fallback for constrained Apache/shared hosting only.
    # Recommended production setup remains: DocumentRoot points to /public.
    RewriteCond %{REQUEST_URI} !^/\.well-known/
    RewriteRule (^|/)\. - [F,L]
    RewriteRule ^(app|bootstrap|config|database|docs|node_modules|resources|routes|storage|tests|vendor)(/|$) - [F,L]
    RewriteRule ^(artisan|composer\.(json|lock)|package(-lock)?\.json|package\.json|phpunit\.xml|vite\.config\.js|VERSION|CHANGELOG\.md|README\.md)$ - [F,L]

    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -d
    RewriteRule ^(.*)$ public/$1 [L]

    RewriteRule ^$ public/index.php [L]
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/index.php [L]
</IfModule>

<FilesMatch "(^\.|\.env$|\.user\.ini$|composer\.(json|lock)$|package(-lock)?\.json$|package\.json$|phpunit\.xml$|vite\.config\.js$|VERSION$|CHANGELOG\.md$|README\.md$)">
    Require all denied
</FilesMatch>
